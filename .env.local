## APP Configuration ##
APP_ENV=local
CONTAINER_BUILD=false

# API
API_PORT=8080
ROUTE_PREFIX=''

## Service data ##
SERVICE_NAME=pigeon-swarm

## MESSAGE BUS ##
TRANSPORT_DSN="in-memory://"
TRANSPORT_MAX_RETRIES=0
TRANSPORT_RETRY_DELAY=0

## LOGS ##
LOG_LEVEL="debug"
LOG_URL="/var/log/"

# IPFS
IPFS_STORAGE_PATH="./ipfs_storage"

# MongoDB
MONGO_URL="mongodb://mongodb:27017"
MONGO_DATABASE="pigeon_swarm"
