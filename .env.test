## APP Configuration ##
APP_ENV=test
CONTAINER_BUILD=false

# API
API_PORT=8081
ROUTE_PREFIX=''

## Service data ##
SERVICE_NAME=pigeon-swarm

## MESSAGE BUS ##
TRANSPORT_DSN="libp2p-gossipsub://"
PUBSUB_TOPIC_PREFIX="pigeon-swarm-test"
TRANSPORT_MAX_RETRIES=0
TRANSPORT_RETRY_DELAY=0

## LOGS ##
LOG_LEVEL="info"
LOG_URL="/var/log/"

# IPFS
IPFS_STORAGE_PATH="memory"
DEBUG_NETWORK=true
PIGEON_RELAY_DISCOVERY_ENABLED=false

# Local DB
PIGEON_LOCAL_DB_PATH="./local_storage/test"
