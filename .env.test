## APP Configuration ##
APP_ENV=test
CONTAINER_BUILD=false

# API
API_PORT=8081
ROUTE_PREFIX=''
JWT_SECRET=supersecretkey

## Service data ##
SERVICE_NAME=pigeon-swarm

## MESSAGE BUS ##
TRANSPORT_DSN="in-memory://"
TRANSPORT_MAX_RETRIES=0
TRANSPORT_RETRY_DELAY=0

## LOGS ##
LOG_LEVEL="debug"
LOG_URL="/var/log/"

# IPFS
IPFS_STORAGE_PATH="memory"

# MongoDB
MONGO_URL="mongodb://localhost:27017"
MONGO_DATABASE="pigeon_swarm_test"
