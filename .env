## APP Configuration ##
APP_ENV=$NODE_ENV
CONTAINER_BUILD=false

# API
API_PORT=80
ROUTE_PREFIX=''
JWT_SECRET="$JWT_SECRET"

## Service data ##
SERVICE_NAME=pigeon-swarm

## MONGO ##
MONGO_URI="$MONGO_URI"

## MESSAGE BUS ##
TRANSPORT_DSN="$TRANSPORT_DSN"
TRANSPORT_MAX_RETRIES=0
TRANSPORT_RETRY_DELAY=0

## LOGS ##
LOG_LEVEL="debug"
LOG_URL="/var/log/"
