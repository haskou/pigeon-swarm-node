## APP Configuration ##
APP_ENV=local
CONTAINER_BUILD=false

# API
API_PORT=80
ROUTE_PREFIX=''

## Service data ##
SERVICE_NAME=pigeon-swarm

## MESSAGE BUS ##
TRANSPORT_DSN="in-memory://"
TRANSPORT_MAX_RETRIES=0
TRANSPORT_RETRY_DELAY=0

## LOGS ##
LOG_LEVEL="debug"
LOG_URL="/var/log/"

# IPFS
IPFS_STORAGE_PATH="./ipfs_storage"
# Optional private PSK circuit relay range. Expose the whole range in Docker
# when this node should relay private IPFS networks.
# PIGEON_PRIVATE_RELAY_PORT_START=4100
# PIGEON_PRIVATE_RELAY_PORT_END=4199
# PIGEON_RELAY_DATA_LIMIT_BYTES=67108864
# PIGEON_PUBLIC_HOST=relay.example.com
