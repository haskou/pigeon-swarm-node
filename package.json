{
  "name": "pigeon-swarm-node",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "lint": "eslint ./src --ext .ts",
    "lint:fix": "eslint ./src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "build": "ts-patch install && tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "local": "nodemon",
    "local:start": "node --inspect=0.0.0.0:9229 -r ts-node/register -r tsconfig-paths/register src/index.ts",
    "postinstall": "node scripts/patch-helia-bitswap-limited-connections.js && node scripts/patch-orbitdb-limited-connections.js && node scripts/patch-libp2p-kad-dht-routing-table.js",
    "test": "npm-run-all lint test:unit test:api test:consumer test:scheduler",
    "test:unit": "jest --passWithNoTests",
    "test:api": "NODE_ENV=test cucumber-js -p api --publish-quiet",
    "test:api:real-ipfs": "NODE_ENV=test PIGEON_API_TEST_REAL_IPFS=true IPFS_STORAGE_PATH=./memory/ipfs cucumber-js -p api_support --publish-quiet tests/api/features/ipfs-api/PostNetworkIPFSContentRoute.feature tests/api/features/communities-api/PostCommunityInviteRoute.feature tests/api/features/identities-api/PostIdentityRoute.feature tests/api/features/keychains-api/PostKeychainRoute.feature",
    "test:api:only": "NODE_ENV=test cucumber-js -p api --publish-quiet --tags @Only",
    "test:consumer": "NODE_ENV=test cucumber-js -p consumer --publish-quiet",
    "test:consumer:only": "NODE_ENV=test cucumber-js -p consumer --publish-quiet --tags @Only",
    "test:e2e:real-transport": "npm-run-all test:e2e:real-transport:conversation test:e2e:real-transport:private-ipfs-relay test:e2e:real-transport:private-relay-discovery test:e2e:real-transport:orbitdb-spike",
    "test:e2e:real-transport:conversation": "tsx -r tsconfig-paths/register tests/e2e/real-transport/two-real-node-gossipsub.ts",
    "test:e2e:real-transport:private-ipfs-relay": "tsx -r tsconfig-paths/register tests/e2e/real-transport/two-private-ipfs-relay.ts",
    "test:e2e:real-transport:private-relay-discovery": "tsx -r tsconfig-paths/register tests/e2e/real-transport/two-private-relay-discovery.ts",
    "test:e2e:real-transport:orbitdb-spike": "tsx -r tsconfig-paths/register tests/e2e/real-transport/two-private-orbitdb-spike.ts",
    "test:scheduler": "NODE_ENV=test cucumber-js -p scheduler --publish-quiet",
    "test:scheduler:only": "NODE_ENV=test cucumber-js -p scheduler --publish-quiet --tags @Only",
    "test:ci": "npm-run-all test:unit test:api test:api:real-ipfs test:consumer test:scheduler",
    "test:coverage:all": "yarn test:coverage:clean && yarn test:coverage:unit && yarn test:coverage:api && yarn test:coverage:consumer && yarn test:coverage:report",
    "test:coverage:clean": "rm -rf coverage/*",
    "test:coverage:unit": "jest --collect-coverage --runInBand && mv coverage/unit/coverage-final.json coverage/coverage-unit.json",
    "test:coverage:api": "nyc --reporter=json --report-dir coverage/api cucumber-js -p api --publish-quiet && mv coverage/api/coverage-final.json coverage/coverage-api.json",
    "test:coverage:consumer": "nyc --reporter=json --report-dir coverage/consumer cucumber-js -p consumer --publish-quiet && mv coverage/consumer/coverage-final.json coverage/coverage-consumer.json",
    "test:coverage:report": "nyc report -t coverage --reporter=json-summary --reporter=text --report-dir=coverage > coverage/coverage-summary.txt",
    "test:coverage:report:html": "nyc report -t coverage --reporter=html --report-dir=coverage/html",
    "test:coverage:all:html": "yarn test:coverage:clean && yarn test:coverage:unit && yarn test:coverage:api && yarn test:coverage:command && yarn test:coverage:report:html",
    "test:api:feature": "NODE_ENV=test cucumber-js -p api_support --publish-quiet"
  },
  "keywords": [],
  "author": "",
  "license": "SEE LICENSE IN LICENSE",
  "dependencies": {
    "@haskou/ddd-kernel": "2.0.6",
    "@haskou/value-objects": "2.13.1",
    "@helia/block-brokers": "^5.2.4",
    "@helia/json": "^5.1.1",
    "@helia/routers": "^5.1.1",
    "@helia/unixfs": "^7.2.1",
    "@libp2p/bootstrap": "12.0.25",
    "@libp2p/circuit-relay-v2": "^4.2.7",
    "@libp2p/gossipsub": "^16.0.3",
    "@libp2p/pnet": "^3.0.23",
    "@multiformats/multiaddr": "^13.0.3",
    "@noble/curves": "2.2.0",
    "@orbitdb/core": "4.0.0",
    "amqplib": "2.0.1",
    "axios": "^1.18.1",
    "blockstore-core": "^6.1.3",
    "blockstore-fs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "datastore-fs": "^11.0.4",
    "express": "^5.2.1",
    "express-winston": "^4.2.0",
    "fs-extra": "^11.3.6",
    "helia": "^6.1.4",
    "ipns": "10.1.6",
    "level": "^10.0.0",
    "module-alias": "^2.3.4",
    "node-cron": "4.5.0",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "web-push": "^3.6.7",
    "winston": "^3.19.0",
    "ws": "^8.21.0"
  },
  "resolutions": {
    "@libp2p/interface": "3.2.4",
    "interface-datastore": "10.0.1",
    "wrap-ansi": "7.0.0",
    "string-width": "4.2.3"
  },
  "devDependencies": {
    "@cucumber/cucumber": "7.3.2",
    "@faker-js/faker": "^10.3.0",
    "@haskou/eslint-config": "^0.2.0",
    "@types/chai": "^5.2.3",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.13.3",
    "@types/web-push": "^3.6.4",
    "@types/ws": "^8.18.1",
    "chai": "^6.2.2",
    "chai-subset": "^1.6.0",
    "cucumber-tsflow": "^4.0.0-preview.7",
    "eslint": "^10.5.0",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "nodemon": "^3.1.14",
    "npm-run-all2": "^9.0.2",
    "nyc": "^18.0.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-transform-paths": "^3.5.6"
  }
}
