{
  "name": "pigeon-swarm-node",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "lint": "eslint ./src --ext .ts",
    "lint:fix": "eslint ./src --ext .ts --fix",
    "build": "ts-patch install && tsc --project tsconfig.build.json",
    "start": "pm2-runtime start dist/index.js",
    "stop": "pm2-runtime stop node",
    "local": "nodemon",
    "local:start": "node --inspect=0.0.0.0:9229 -r ts-node/register -r tsconfig-paths/register src/index.ts",
    "test": "npm-run-all lint test:unit test:api test:consumer test:scheduler",
    "test:unit": "jest --passWithNoTests",
    "test:api": "find tests/api/features -name '*.feature' -print | sort | while read feature; do yarn test:api:feature \"$feature\" || exit 1; done",
    "test:api:only": "NODE_ENV=test cucumber-js -p api --publish-quiet --tags @Only",
    "test:consumer": "NODE_ENV=test cucumber-js -p consumer --publish-quiet",
    "test:consumer:only": "NODE_ENV=test cucumber-js -p consumer --publish-quiet --tags @Only",
    "test:scheduler": "NODE_ENV=test cucumber-js -p scheduler --publish-quiet",
    "test:scheduler:only": "NODE_ENV=test cucumber-js -p scheduler --publish-quiet --tags @Only",
    "test:ci": "npm-run-all test:unit test:api test:consumer test:scheduler",
    "test:coverage:all": "yarn test:coverage:clean && yarn test:coverage:unit && yarn test:coverage:api && yarn test:coverage:consumer && yarn test:coverage:report",
    "test:coverage:clean": "rm -rf coverage/*",
    "test:coverage:unit": "jest --collect-coverage --runInBand && mv coverage/unit/coverage-final.json coverage/coverage-unit.json",
    "test:coverage:api": "nyc --reporter=json --report-dir coverage/api cucumber-js -p api --publish-quiet && mv coverage/api/coverage-final.json coverage/coverage-api.json",
    "test:coverage:consumer": "nyc --reporter=json --report-dir coverage/consumer cucumber-js -p consumer --publish-quiet && mv coverage/consumer/coverage-final.json coverage/coverage-consumer.json",
    "test:coverage:report": "nyc report -t coverage --reporter=json-summary --reporter=text --report-dir=coverage > coverage/coverage-summary.txt",
    "test:coverage:report:html": "nyc report -t coverage --reporter=html --report-dir=coverage/html",
    "test:coverage:all:html": "yarn test:coverage:clean && yarn test:coverage:unit && yarn test:coverage:api && yarn test:coverage:command && yarn test:coverage:report:html",
    "test:api:feature": "NODE_ENV=test cucumber-js -p api_support --publish-quiet"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@chainsafe/libp2p-gossipsub": "^14.1.2",
    "@haskou/value-objects": "^2.6.0",
    "@helia/json": "^5.0.7",
    "@helia/strings": "^5.0.7",
    "@helia/unixfs": "^7.0.4",
    "@libp2p/pnet": "^3.0.13",
    "@multiformats/multiaddr": "^13.0.1",
    "amqplib": "^0.10.9",
    "axios": "^1.6.7",
    "blockstore-core": "^6.1.2",
    "blockstore-fs": "^3.0.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "class-validator-jsonschema": "^5.1.0",
    "cors": "^2.8.6",
    "datastore-fs": "^11.0.2",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-winston": "^4.2.0",
    "fs-extra": "^11.3.4",
    "helia": "^6.0.21",
    "jsonwebtoken": "^9.0.3",
    "module-alias": "^2.3.4",
    "node-cron": "^4.2.1",
    "node-dependency-injection": "^3.2.6",
    "path": "^0.12.7",
    "pm2-runtime": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "routing-controllers-openapi": "^5.0.1",
    "winston": "^3.19.0",
    "ws": "^8.20.0"
  },
  "resolutions": {
    "wrap-ansi": "7.0.0",
    "string-width": "4.1.0"
  },
  "devDependencies": {
    "@cucumber/cucumber": "7.3.2",
    "@faker-js/faker": "^10.3.0",
    "@types/amqplib": "^0.10.8",
    "@types/chai": "^5.2.3",
    "@types/chai-subset": "^1.3.6",
    "@types/express": "^5.0.6",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.3.5",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "chai": "^6.2.2",
    "chai-subset": "^1.6.0",
    "cucumber-tsflow": "^4.0.0-preview.7",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-perfectionist": "^4.15.0",
    "eslint-plugin-prettier": "^5.5.1",
    "eslint-plugin-sonarjs": "^3.0.4",
    "eslint-plugin-unused-imports": "^4.1.4",
    "jest": "^30.2.0",
    "jest-mock-extended": "^4.0.0",
    "jest-runner-tsc": "^1.6.0",
    "mockttp": "^4.2.2",
    "mongodb": "^7.2.0",
    "mongodb-memory-server": "^11.1.0",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "nyc": "^18.0.0",
    "prettier": "^3.8.1",
    "prettier-eslint": "^16.4.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "ts-patch": "^3.3.0",
    "ts-transform-paths": "^3.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-transform-paths": "^3.5.6"
  }
}
