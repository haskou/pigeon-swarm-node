@startuml

title Pigeon Swarm - Global System Flow

actor User

box "Local Node (Standalone App)"
participant "Web UI"
participant "Auth Service"
participant "Identity Service"
participant "Peer Network"
participant "Replication Engine"
participant "Local Storage"
participant "IPFS (Helia)"
end box

box "Network"
participant "Peer Node A"
participant "Peer Node B"
participant "Peer Node C"
end box


== LOGIN ==

User -> "Web UI" : open app
"Web UI" -> "Auth Service" : login(password)

"Auth Service" -> "Local Storage" : load encrypted identity
"Auth Service" -> "Auth Service" : derive private key

"Auth Service" -> "Identity Service" : unlock identity
"Identity Service" -> "Web UI" : session established


== NETWORK BOOTSTRAP ==

"Web UI" -> "Peer Network" : connect()

"Peer Network" -> "Peer Network" : load known peers

alt no peers
"Peer Network" -> "Peer Node A" : bootstrap connect
end

"Peer Network" -> "Peer Network" : establish gossip channels


== PEER DISCOVERY ==

loop gossip network

"Peer Node A" -> "Peer Network" : peer list fragment
"Peer Network" -> "Local Storage" : store peer

"Peer Network" -> "Peer Node B" : handshake
"Peer Node B" -> "Peer Network" : handshake response

end


== SEARCH USER ==

User -> "Web UI" : search username

"Web UI" -> "Identity Service" : search(name)

"Identity Service" -> "Peer Network" : request identity hints

"Peer Network" -> "Peer Node A" : query
"Peer Node A" -> "IPFS (Helia)" : fetch profile CID

"IPFS (Helia)" -> "Peer Network" : profile object
"Peer Network" -> "Identity Service" : identity data

"Identity Service" -> "Web UI" : profile results


== OPEN CONVERSATION ==

User -> "Web UI" : open chat

"Web UI" -> "Replication Engine" : load conversation log

"Replication Engine" -> "IPFS (Helia)" : fetch CRDT log

"IPFS (Helia)" -> "Replication Engine" : log entries

"Replication Engine" -> "Web UI" : messages


== SEND MESSAGE ==

User -> "Web UI" : send message

"Web UI" -> "Identity Service" : get public key
"Web UI" -> "Web UI" : encrypt message

"Web UI" -> "Replication Engine" : append message

"Replication Engine" -> "IPFS (Helia)" : store block
"IPFS (Helia)" -> "Replication Engine" : CID

"Replication Engine" -> "Local Storage" : update log head

"Replication Engine" -> "Peer Network" : broadcast log head


== NETWORK PROPAGATION ==

"Peer Network" -> "Peer Node B" : gossip new head
"Peer Node B" -> "Replication Engine" : request missing blocks

"Peer Node B" -> "IPFS (Helia)" : fetch message block

"IPFS (Helia)" -> "Peer Node B" : message data

"Peer Node B" -> "Replication Engine" : merge CRDT


== SEND MEDIA ==

User -> "Web UI" : upload image

"Web UI" -> "IPFS (Helia)" : add file

"IPFS (Helia)" -> "Web UI" : CID

"Web UI" -> "Replication Engine" : message with CID

"Replication Engine" -> "Peer Network" : gossip message


== OFFLINE NODE RECOVERY ==

"Peer Node C" -> "Peer Network" : reconnect

"Peer Network" -> "Peer Node C" : gossip latest heads

"Peer Node C" -> "Replication Engine" : detect missing entries

"Peer Node C" -> "IPFS (Helia)" : fetch blocks

"Replication Engine" -> "Local Storage" : rebuild log

@enduml
