@startuml

title Pigeon Swarm - Identities Context

package "identities.domain" {
  class Identity <<AggregateRoot>> {
    -id: IdentityId
    -encryptedKeyPair: EncryptedKeyPair
    -version: number
    -previousIdentityExternalIdentifier?: IdentityExternalIdentifier
    -networks: UniqueObjectArray<NetworkId>
    -profile: Profile
    -timestamp: Timestamp
    -signature: Signature
    +fromSignedPublication(primitives): Identity
    +updateProfile(profile, password): Identity
    +updateNetworks(networks, password): Identity
  }

  class Profile {
    -name: ProfileName
    -handle?: ProfileHandle
    -biography?: ProfileBiography
    -picture?: ProfileImage
    -banner?: ProfileBanner
  }

  class ProfileName <<ValueObject>>
  class ProfileHandle <<ValueObject>>
  class ProfileBiography <<ValueObject>>
  class ProfileImage <<ValueObject>>
  class ProfileBanner <<ValueObject>>
  class IdentityExternalIdentifier <<ValueObject>>

  class IdentityCandidate {
    -externalIdentifier: IdentityExternalIdentifier
    -identity: Identity
    +getExternalIdentifier(): IdentityExternalIdentifier
    +getIdentity(): Identity
    +isIdentifiedBy(identityId): boolean
    +isNewerThan(other): boolean
  }

  note right of ProfileHandle
    Stored lowercase without @.
    Allowed characters: letters,
    numbers, dots, hyphens and underscores.
  end note

  note right of ProfileImage
    Public IPFS CID for profile image/avatar.
    Base64/data URLs are not stored here.
  end note

  note right of ProfileBanner
    Public IPFS CID for profile banner.
    Base64/data URLs are not stored here.
  end note

  class IdentitySignatureDomainService {
    +generateSignature(payload, encryptedKeyPair, password): Promise<Signature>
    +isValidSignature(identityId, payload, signature): boolean
  }

  class IdentityResolutionDomainService {
    +validate(identity: Identity): void
    +chooseCurrent(candidates: Identity[]): Identity
  }

  interface IdentityRepository {
    +save(identity: Identity): Promise<IdentityExternalIdentifier>
    +findById(id: IdentityId): Promise<Identity>
    +findByHandle(handle: ProfileHandle): Promise<Identity>
    +findByExternalIdentifier(externalIdentifier): Promise<Identity?>
    +findCandidateReferencesById(id): Promise<IdentityCandidate[]>
    +findCandidateByExternalIdentifier(id, externalIdentifier): Promise<IdentityCandidate>
    +findCandidateByHandle(handle): Promise<IdentityCandidate>
    +findCandidatesById(id: IdentityId): Promise<Identity[]>
  }

  interface IdentityNetworkRepository {
    +findByIdentityId(identityId: IdentityId): Promise<NetworkId[]>
  }

  class IdentitySaverService {
    +save(identity): Promise<IdentityExternalIdentifier>
  }

  class IdentityFinderService {
    +findById(identityId): Promise<Identity>
    +findByHandle(handle): Promise<Identity>
  }

  note right of Identity
    Identities can join new networks.
    Updates that remove an existing
    network are rejected.
  end note

  Identity *--> Profile
  Identity o--> NetworkId
  Identity --> IdentityExternalIdentifier
  IdentityCandidate --> Identity
  IdentityCandidate --> IdentityExternalIdentifier
  Profile *--> ProfileName
  Profile --> ProfileHandle
  Profile --> ProfileBiography
  Profile --> ProfileImage
  Profile --> ProfileBanner
  Identity ..> IdentitySignatureDomainService
  IdentityResolutionDomainService --> Identity
  IdentitySaverService --> IdentityRepository
  IdentityFinderService --> IdentityRepository
  IdentityFinderService --> IdentityResolutionDomainService
}

package "identities.application" {
  class IdentityFinder {
    +find(message: IdentityFinderMessage): Promise<Identity>
    +findCandidate(message): Promise<IdentityCandidate>
  }

  class IdentityPublisher {
    +publish(message: IdentityPublishMessage): Promise<Identity>
  }

  class IdentityCandidateRegistrar {
    +register(message: RegisterIdentityCandidateMessage): Promise<void>
  }

  class IdentityNetworksFinder {
    +find(identityId: IdentityId): Promise<NetworkId[]>
  }

  IdentityPublisher --> IdentitySaverService
  IdentityPublisher --> IdentityRepository
  IdentityFinder --> IdentityFinderService
  IdentityCandidateRegistrar --> IdentityRepository
  IdentityNetworksFinder --> IdentityNetworkRepository
}

package "identities.infrastructure" {
  class IpfsIdentityDocument {
    -_id: string
    -version: number
    -previousExternalIdentifier?: string
    -encryptedKeyPair: object
    -networks: string[]
    -profile: object
    -timestamp: number
    -signature: string
  }

  class OrbitDBIdentityMetadataDocument {
    -id: string
    -identityId: string
    -handle?: string
    -cid: string
    -version: number
    -previousCid?: string
    -networkIds: string[]
    -receivedAt: number
  }

  interface IdentityMetadataIndex {
    +save(identity, externalIdentifier): Promise<void>
    +deleteByExternalIdentifier(externalIdentifier): Promise<void>
    +findByIdentityId(identityId): Promise<IdentityMetadataRecord[]>
    +findByHandle(handle): Promise<IdentityMetadataRecord[]>
    +findLatestByNetworkId(networkId): Promise<IdentityMetadataRecord[]>
  }

  class OrbitDBIdentityMetadataIndex {
    +save(identity, externalIdentifier): Promise<void>
    +findByIdentityId(identityId): Promise<IdentityMetadataRecord[]>
    +findByHandle(handle): Promise<IdentityMetadataRecord[]>
  }

  class MetadataIdentityNetworkRepository {
    +findByIdentityId(identityId): Promise<NetworkId[]>
  }

  class IpfsIdentityRepository {
    +save(identity: Identity): Promise<IdentityExternalIdentifier>
    +findById(id: IdentityId): Promise<Identity>
    +findByHandle(handle: ProfileHandle): Promise<Identity>
    +findByExternalIdentifier(externalIdentifier): Promise<Identity?>
    +findCandidateByExternalIdentifier(id, externalIdentifier): Promise<IdentityCandidate>
    +findCandidatesById(id: IdentityId): Promise<Identity[]>
  }

  class IpfsIdentityRouting {
    +republish(): Promise<number>
  }

  note right of IpfsIdentityRepository
    Encapsulates IPFS documents and DHT
    head hints. Uses the metadata index
    as infrastructure cache/read model.
  end note

  IpfsIdentityRepository ..|> IdentityRepository
  IpfsIdentityRouting --> IpfsIdentityRepository
  MetadataIdentityNetworkRepository ..|> IdentityNetworkRepository
  OrbitDBIdentityMetadataIndex ..|> IdentityMetadataIndex
  IpfsIdentityRepository --> IpfsIdentityDocument
  IpfsIdentityRepository --> IdentityMetadataIndex
  MetadataIdentityNetworkRepository --> IdentityMetadataIndex
  OrbitDBIdentityMetadataIndex --> OrbitDBIdentityMetadataDocument
}

@enduml
