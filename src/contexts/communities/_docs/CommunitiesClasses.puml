package "communities/domain" {
  class Community {
    - id: CommunityId
    - networkId: NetworkId
    - ownerIdentityId: IdentityId
    - profile: CommunityProfile
    - membership: CommunityMembership
    - channels: CommunityChannels
    - settings: CommunitySettings
    + create(ownerIdentityId, networkId, profile, settings): Community
    + joinWithInvite(member): void
    + createInvite(actor, expiresAt?, maxUses?, encryptedCommunityKey?): CommunityInvite
    + inviteMember(actor, invitedIdentityId): CommunityMembershipRequest
    + acceptMembershipRequest(actor, membershipRequest): void
    + declineMembershipRequest(actor, membershipRequest): void
    + isAutoJoinEnabled(): boolean
    + leave(member): void
    + banMember(actor, member): void
    + unbanMember(actor, member): void
    + sendChannelMessage(metadata, payload, signature, attachments, mentions): CommunityChannelMessage
    + acceptSentChannelMessage(message, payload): CommunityChannelMessage
    + editChannelMessage(actor, targetMessage, channelId, payload, signature, editedAt, attachments, mentions): CommunityChannelMessage
    + reactWithSticker(identityId, channelId, messageId, emoji): CommunityChannelMessageReaction
    + deleteChannelMessage(actor, targetMessage, channelId): void
    + viewTextChannel(identityId, channelId): void
    + manageChannelMessages(identityId, channelId): void
    + searchTextChannelMessages(identityId, channelId): void
    + viewModerationLog(identityId): void
    + addTextChannel(actor, name): CommunityTextChannel
    + addRole(actor, name, permissions): CommunityRole
    + assignRoles(actor, member, roleIds): void
    + updateChannelPermissions(actor, channelId, permissions): void
    + renameChannel(actor, channelId, name): void
    + updateProfile(actor, name, description, banner?): void
    + viewAsMember(identityId): void
    + requestMembership(identityId): void
  }

  class CommunityAccessValidator {
    - ownerIdentityId: IdentityId
    - membership: CommunityMembership
    - channels: CommunityChannels
    - settings: CommunitySettings
    + assertCanViewTextChannel(identityId, channelId): void
    + assertCanSendChannelMessage(identityId, channelId, payload, mentions): void
    + assertCanEditMessage(actor, targetMessage, channelId, payload, mentions): void
    + assertCanDeleteMessage(actor, targetMessage, channelId): void
    + visibleChannelsFor(identityId): object
    + visibleTextChannelIdsFor(identityId): CommunityChannelId[]
    + visibleMembersForTextChannel(channelId): IdentityId[]
  }

  class CommunityMembership {
    - members: IdentityId[]
    - bannedMembers: IdentityId[]
    - roles: CommunityRoles
    + add(member): void
    + ban(member): void
    + unban(member): void
    + remove(member): void
    + assignRoles(member, roleIds): void
    + isBanned(identityId): boolean
    + isMember(identityId): boolean
  }

  class CommunityRoles {
    - roles: CommunityRole[]
    - memberRoles: CommunityMemberRoleAssignment[]
    + add(name, permissions): CommunityRole
    + update(roleId, name, permissions): void
    + remove(roleId): void
    + assign(identityId, roleIds): void
    + memberHasPermission(identityId, permission): boolean
  }

  class CommunityRole {
    - id: CommunityRoleId
    - name: CommunityRoleName
    - permissions: CommunityPermission[]
    - builtIn: boolean
    + everyone(): CommunityRole
    + create(name, permissions): CommunityRole
    + allows(permission): boolean
  }

  class CommunityChannels {
    - textChannels: CommunityTextChannel[]
    - voiceChannels: CommunityVoiceChannel[]
    + addText(name): CommunityTextChannel
    + addVoice(name): CommunityVoiceChannel
    + updatePermissions(channelId, permissions): void
    + visiblePrimitivesFor(canView): object
  }

  class CommunityChannelPermissions {
    - visibleRoleIds: CommunityRoleId[]
    + visibleForEveryone(): CommunityChannelPermissions
    + updateVisibleRoleIds(roleIds): void
  }

  class CommunityTextChannel {
    - id: CommunityChannelId
    - name: CommunityChannelName
    - permissions: CommunityChannelPermissions
    - createdAt: Timestamp
    + create(name): CommunityTextChannel
    + rename(name): void
  }

  class CommunityVoiceChannel {
    - id: CommunityChannelId
    - name: CommunityChannelName
    - permissions: CommunityChannelPermissions
    - createdAt: Timestamp
    + create(name): CommunityVoiceChannel
    + rename(name): void
  }

  class CommunityChannelMessage {
    - id: CommunityChannelMessageId
    - communityId: CommunityId
    - channelId: CommunityChannelId
    - authorIdentityId: IdentityId
    - payload: CommunityChannelMessagePayload
    - signature: Signature
    - createdAt: Timestamp
    - attachmentExternalIdentifiers: CommunityChannelMessageAttachments
    - mentions: CommunityChannelMessageMentions
    + create(...): CommunityChannelMessage
  }

  class CommunityChannelMessageAttachments {
    - attachments: CommunityChannelAttachmentId[]
    + toArray(): CommunityChannelAttachmentId[]
  }

  class CommunityChannelMessageMentions {
    - mentions: CommunityChannelMessageMention[]
    + toArray(): CommunityChannelMessageMention[]
  }

  class CommunityChannelThreadSummary {
    - rootMessageId: CommunityChannelMessageId
    - lastReplyMessageId: CommunityChannelMessageId
    - replyCount: number
    - lastReplyAt: Timestamp
    + withReply(replyMessageId, repliedAt): CommunityChannelThreadSummary
  }

  class CommunityChannelMessageReaction {
    - communityId: CommunityId
    - channelId: CommunityChannelId
    - messageId: CommunityChannelMessageId
    - authorIdentityId: IdentityId
    - emoji: CommunityChannelMessageReactionEmoji
    - createdAt: Timestamp
  }

  class CommunityModerationLogEntry {
    - id: CommunityModerationLogId
    - communityId: CommunityId
    - actorIdentityId: IdentityId
    - action: CommunityModerationAction
    - target: CommunityModerationTarget
    - details: CommunityModerationLogDetails
    - createdAt: Timestamp
    + record(communityId, actorIdentityId, action, target, details?): CommunityModerationLogEntry
  }

  class CommunityModerationTarget {
    - type: CommunityModerationTargetType
    - id: StringValueObject
  }

  class CommunityModerationLogDetails

  class CommunityProfile {
    - name: CommunityName
    - description: CommunityDescription
    - avatar: CommunityAvatar?
    - banner: CommunityBanner?
  }

  class CommunitySettings {
    - createdAt: Timestamp
    - discoverable: boolean
    - visibility: CommunityVisibility
    - autoJoinEnabled: boolean
    + ensureMessagePayloadAllowed(payload): void
    + ensureMessageSearchAvailable(): void
  }

  class CommunityInvite {
    - token: CommunityInviteToken
    - communityId: CommunityId
    - creatorIdentityId: IdentityId
    - createdAt: Timestamp
    - expiresAt: Timestamp?
    - maxUses: CommunityInviteMaxUses
    - uses: CommunityInviteUses
    - encryptedCommunityKey: EncryptedCommunityInviteKey?
    + create(communityId, creatorIdentityId, expiresAt?, maxUses?, encryptedCommunityKey?): CommunityInvite
    + checkAcceptanceAvailability(now?): void
    + accept(now?): void
  }

  class CommunityMembershipRequest {
    - id: CommunityRequestId
    - communityId: CommunityId
    - type: CommunityRequestType
    - status: CommunityRequestStatus
    - creatorIdentityId: IdentityId
    - identityId: IdentityId
    - timestamps: CommunityMembershipRequestTimestamps
    + invitation(communityId, creatorIdentityId, identityId): CommunityMembershipRequest
    + request(communityId, requesterIdentityId): CommunityMembershipRequest
    + accept(actorIdentityId, ownerIdentityId): void
    + decline(actorIdentityId, ownerIdentityId): void
  }

